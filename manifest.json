{
  "manifest_version": 3,
  "name": "WebSurf Helper",
  "version": "0.1.0",
  "description": "Double-click links to open in a new tab, and customize keyboard scroll distance.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
